      "category": "COMMAND_INJECTION",
      "severity": "CRITICAL",
      "pattern": "(?:[;|&`$]\\s*(?:cat|ls|pwd|id|whoami|wget|curl|bash|sh|cmd|powershell|exec|system|passthru|shell_exec|proc_open|popen))",
