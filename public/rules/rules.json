    {
      "id": "PROMPT-005",
      "name": "Goal Hijacking",
      "description": "Detects prompt injection attempting to change AI objectives",
      "category": "PROMPT_INJECTION",
      "severity": "CRITICAL",
      "pattern": "(?:your\\s+(?:new|real|true|actual)\\s+(?:goal|objective|purpose|mission|task)\\s+is|from\\s+now\\s+on\\s+you|forget\\s+(?:everything|all)\\s+(?:you\\s+(?:were|are)|about))",
      "flags": "gi",
      "testCases": {
