      "name": "Token Smuggling",
      "description": "Detects prompt injection via special delimiters and token manipulation",
      "category": "PROMPT_INJECTION",
      "severity": "HIGH",
      "pattern": "(?:<<<|>>>|\\[INST\\]|\\[/INST\\]|<\\|(?:im_start|im_end|system|user|assistant)\\|>|<s>|</s>|\\[SYS\\]|\\[\\[\\[|\\]\\]\\])",
      "flags": "g",
