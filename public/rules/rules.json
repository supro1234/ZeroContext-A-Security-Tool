  "rules": [
    {
      "id": "XSS-001",
      "name": "Script Tag Injection",
      "description": "Detects <script> tag injection attempts",
      "category": "XSS",
      "severity": "CRITICAL",
      "pattern": "<\\s*script[^>]*>",
      "flags": "gi",
      "testCases": {
        "matches": ["<script>alert(1)</script>", "<SCRIPT SRC=x>"],
        "noMatches": ["// this is a comment", "normal text"]
      },
      "metadata": { "owasp": "A03:2021", "tags": ["xss", "injection"] }
    },
    {
      "id": "XSS-002",
      "name": "JavaScript Event Handler",
      "description": "Detects on* event handler injection (onerror, onload, etc.)",
      "category": "XSS",
      "severity": "CRITICAL",
      "pattern": "\\bon\\w+\\s*=\\s*[\"']?[^\"'\\s>]+",
      "flags": "gi",
      "testCases": {
        "matches": ["<img onerror=alert(1)>", "onload=\"evil()\""],
        "noMatches": ["onclick handler docs"]
      },
      "metadata": { "owasp": "A03:2021", "tags": ["xss", "event-handler"] }
    },
    {
      "id": "XSS-003",
      "name": "Javascript Protocol URI",
      "description": "Detects javascript: protocol in href/src attributes",
      "category": "XSS",
      "severity": "CRITICAL",
      "pattern": "javascript\\s*:",
      "flags": "gi",
      "testCases": {
        "matches": ["href=\"javascript:alert(1)\"", "javascript :void(0)"],
        "noMatches": ["https://example.com"]
      },
      "metadata": { "owasp": "A03:2021", "tags": ["xss", "protocol"] }
    },
    {
      "id": "XSS-004",
      "name": "Data URI with HTML/JS",
      "description": "Detects data: URI schemes that can carry executable content",
      "category": "XSS",
      "severity": "HIGH",
      "pattern": "data\\s*:\\s*text\\/(html|javascript)|data\\s*:\\s*application\\/javascript",
      "flags": "gi",
      "testCases": {
        "matches": ["data:text/html,<script>", "data:application/javascript,alert"],
        "noMatches": ["data:image/png;base64,iVBOR"]
      },
      "metadata": { "owasp": "A03:2021", "tags": ["xss", "data-uri"] }
    },
    {
      "id": "XSS-005",
      "name": "DOM Sink Calls",
      "description": "Detects dangerous DOM sinks: innerHTML, document.write, eval",
      "category": "XSS",
      "severity": "HIGH",
      "pattern": "(?:innerHTML|outerHTML|document\\.write|document\\.writeln|eval\\s*\\(|setTimeout\\s*\\(\\s*[\"']|setInterval\\s*\\(\\s*[\"'])",
      "flags": "gi",
      "testCases": {
        "matches": ["div.innerHTML = userInput", "eval('alert')"],
        "noMatches": ["// innerHTML is bad practice"]
      },
      "metadata": { "owasp": "A03:2021", "tags": ["xss", "dom-sink"] }
    },
    {
      "id": "SQL-001",
      "name": "Classic SQL Injection",
      "description": "Detects ' OR 1=1, UNION SELECT, and common SQLi patterns",
      "category": "SQL_INJECTION",
      "severity": "CRITICAL",
      "pattern": "(?:'\\s*(?:OR|AND)\\s*'?\\d|UNION\\s+(?:ALL\\s+)?SELECT|DROP\\s+TABLE|INSERT\\s+INTO|DELETE\\s+FROM|UPDATE\\s+\\w+\\s+SET)",
      "flags": "gi",
      "testCases": {
        "matches": ["' OR 1=1--", "UNION SELECT * FROM users", "DROP TABLE users"],
        "noMatches": ["SELECT name FROM products"]
      },
      "metadata": { "owasp": "A03:2021", "cve": "general", "tags": ["sqli", "injection"] }
    },
    {
      "id": "SQL-002",
      "name": "SQL Comment Terminator",
      "description": "Detects SQL comment sequences used to truncate queries. Requires either: (a) a quote char immediately before --, (b) a SQL keyword within the same clause before --, or (c) an injected command keyword in the gap between ; and --. A bare semicolon followed only by whitespace then dashes is NOT flagged.",
      "category": "SQL_INJECTION",
      "severity": "HIGH",
      "pattern": "(?:['\"`]\\s*--(?!-{2,})|(?:WHERE|OR|AND|UNION|SELECT|DROP|INSERT|UPDATE|DELETE)\\b[^;\\n]{0,60}--)|(?:;\\s*(?:DROP|DELETE|INSERT|UPDATE|UNION|EXEC(?:UTE)?|ALTER|TRUNCATE)\\b[^\\n]{0,80}--)",
      "flags": "gim",
      "testCases": {
        "matches": ["admin'--", "1=1 OR 1=1--", "'; DROP TABLE users; --", "1; DELETE FROM users; --"],
        "noMatches": ["-- this is a code comment", "----------", "ORDER BY name ASC;  --------", "SELECT * FROM t WHERE id=?;  ----"]
      },
      "metadata": { "owasp": "A03:2021", "tags": ["sqli", "comment"] }
    },
    {
      "id": "SQL-003",
      "name": "Blind SQL Injection Time-Based",
      "description": "Detects SLEEP(), WAITFOR DELAY and similar time-based blind SQLi",
      "category": "SQL_INJECTION",
      "severity": "CRITICAL",
      "pattern": "(?:SLEEP\\s*\\(|WAITFOR\\s+DELAY|BENCHMARK\\s*\\(|pg_sleep\\s*\\()",
      "flags": "gi",
      "testCases": {
        "matches": ["'; SLEEP(5)--", "WAITFOR DELAY '0:0:5'"],
        "noMatches": ["sleep is important for health"]
      },
      "metadata": { "owasp": "A03:2021", "tags": ["sqli", "blind", "time-based"] }
    },
    {
