      "name": "Ignore Previous Instructions",
      "description": "Detects classic prompt injection: ignoring prior context",
      "category": "PROMPT_INJECTION",
      "severity": "CRITICAL",
      "pattern": "(?:ignore\\s+(?:all\\s+)?(?:previous|prior|above|earlier)\\s+(?:instructions?|prompts?|context|rules?)|disregard\\s+(?:all\\s+)?(?:previous|prior))",
      "flags": "gi",
      "testCases": {
